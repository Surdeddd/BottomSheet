{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "jsx": "react-jsx",
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitOverride": true,
    "esModuleInterop": true,
    "isolatedModules": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "forceConsistentCasingInFileNames": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "allowSyntheticDefaultImports": true,
    "useDefineForClassFields": true,
    "verbatimModuleSyntax": false,
    "outDir": "./dist",
    "rootDir": ".",
    "paths": {
      "@surdeddd/bottom-sheet": ["./src/index.ts"],
      "@surdeddd/bottom-sheet/react": ["./src/react/index.ts"],
      "@surdeddd/bottom-sheet/vue": ["./src/vue/index.ts"],
      "@surdeddd/bottom-sheet/element": ["./src/web-component/index.ts"],
      "@surdeddd/bottom-sheet/solid": ["./src/solid/index.tsx"]
    }
  },
  "include": ["src/**/*", "demo/**/*", "tests/**/*"],
  "exclude": ["node_modules", "dist", "examples", "patches"]
}
