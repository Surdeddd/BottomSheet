# Dependencies + build artifacts
node_modules/
dist/
demo/dist/
coverage/
*.tsbuildinfo
# Vite hot-reload temp files (e.g. vite.config.ts.timestamp-1777745954308-*.mjs)
vite.config.ts.timestamp-*.mjs

# Caches
.cache/
.vite/
.turbo/
.next/
.nuxt/
.output/
.eslintcache
.parcel-cache/
.swc/
.astro/
.svelte-kit/
.angular/

# OS / editor cruft
.DS_Store
# macOS resource-fork sidecars that AppleDouble copies onto non-HFS drives
._*
.AppleDouble
.LSOverride
.Spotlight-V100
.Trashes
# Windows
Thumbs.db
ehthumbs.db
desktop.ini
$RECYCLE.BIN/
# Linux
.directory
.Trash-*
*~
# Editor swap / backup files (vim, emacs, nano)
*.swp
*.swo
*.swn
.*.swp
.*.swo
*.bak
\#*\#
.\#*
.netrwhist
# IDE / editor settings
.idea/
.vscode/
.vs/
.fleet/
.zed/
.cursor/
.history/
*.code-workspace

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Secrets / env files (keep .env.example tracked)
.env
.env.*
!.env.example

# npm pack / publish artifacts
*.tgz

# Test outputs
test-results/
playwright-report/
.playwright-mcp/
# Auto-generated by tests/e2e/benchmark.spec.ts + headtohead.spec.ts —
# raw samples + perf-comparison table regenerate per run, no point in
# committing the noise. The hand-written README in tests/benchmark/ is
# the durable reference.
tests/benchmark/results.json
tests/benchmark/report.md
# Vitest run-state
.nyc_output/
.tap-output*
# Visual regression: ignore comparison/diff artifacts but COMMIT baseline
# *.png snapshots under tests/e2e/visual-regression.spec.ts-snapshots/.
**/*-actual.png
**/*-diff.png

# Scratch screenshots / one-off PNGs at repo root from manual playwright runs.
# Baselines under tests/e2e/**/-snapshots/ are explicitly committed; the
# leading slash anchors these patterns to the repo root only.
/*.png
/demo-*.png
/mobile-*.png
/desktop-*.png
/wc-*.png
/svelte-*.png
/solid-*.png
/lit-*.png

# Husky internals (keep .husky/pre-commit tracked, ignore auto-installed _ dir)
.husky/_/

# Cloud-platform local state
.vercel/
.netlify/

# Yarn berry / pnpm local state
.yarn/cache/
.yarn/install-state.gz
.pnpm-store/

# Local agent / CLI state — assistant/agent runtime artifacts. NEVER commit:
# session state, conversation logs, scheduled-task locks, agent ID files,
# debug dumps. Each tool keeps a different folder shape, so list them all.
.claude/
.claude-tools/
.cursor-tools/
.aider*
.copilot/
.codeium/
.continue/
.windsurf/
.junie/
.kilo/
.tabnine/
.sourcegraph/
.openai/
.anthropic/

# Local-only overrides (per-developer config that mustn't leak to team)
*.local
.local/
local.json
local.yml
local.yaml

# Coverage variants (in addition to the `coverage/` dir already listed)
lcov.info
*.lcov

# Storybook (lib supports many frameworks — plausible future addition)
storybook-static/
.storybook-out/

# Monorepo tooling state
.nx/cache/
.rush/
node_modules.nosync/

# Bun / Deno tooling state (lockfiles deno.lock / bun.lockb stay tracked)
.bun/
.deno/
.vercel
