{
  "name": "@surdeddd/bottom-sheet",
  "version": "0.4.0",
  "description": "Universal, headless bottom sheet — framework-agnostic core with React, Vue 3, Svelte, Solid, Qwik, Preact, Lit and Custom Element adapters. Pointer Events, snap points, momentum, a11y, SSR-safe.",
  "type": "module",
  "license": "MIT",
  "author": "Surdeddd",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Surdeddd/BottomSheet.git"
  },
  "homepage": "https://github.com/Surdeddd/BottomSheet#readme",
  "bugs": {
    "url": "https://github.com/Surdeddd/BottomSheet/issues"
  },
  "keywords": [
    "bottom-sheet",
    "modal",
    "drawer",
    "headless",
    "framework-agnostic",
    "react",
    "vue",
    "svelte",
    "solid-js",
    "qwik",
    "preact",
    "lit",
    "web-component",
    "ssr",
    "a11y",
    "snap-points",
    "gesture",
    "pointer-events"
  ],
  "sideEffects": [
    "./dist/styles.css",
    "./dist/themes/ios.css",
    "./dist/themes/material.css",
    "./dist/themes/vercel.css",
    "./dist/element.js",
    "./dist/element.cjs",
    "./dist/element.iife.global.js"
  ],
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./react": {
      "import": {
        "types": "./dist/react.d.ts",
        "default": "./dist/react.js"
      },
      "require": {
        "types": "./dist/react.d.cts",
        "default": "./dist/react.cjs"
      }
    },
    "./preact": {
      "import": {
        "types": "./dist/preact.d.ts",
        "default": "./dist/preact.js"
      },
      "require": {
        "types": "./dist/preact.d.cts",
        "default": "./dist/preact.cjs"
      }
    },
    "./vue": {
      "import": {
        "types": "./dist/vue.d.ts",
        "default": "./dist/vue.js"
      },
      "require": {
        "types": "./dist/vue.d.cts",
        "default": "./dist/vue.cjs"
      }
    },
    "./element": {
      "import": {
        "types": "./dist/element.d.ts",
        "default": "./dist/element.js"
      },
      "require": {
        "types": "./dist/element.d.cts",
        "default": "./dist/element.cjs"
      }
    },
    "./svelte": {
      "svelte": "./dist/svelte-src/index.js",
      "import": {
        "types": "./dist/svelte.d.ts",
        "default": "./dist/svelte.js"
      },
      "require": {
        "types": "./dist/svelte.d.cts",
        "default": "./dist/svelte.cjs"
      }
    },
    "./overlay": {
      "import": {
        "types": "./dist/overlay.d.ts",
        "default": "./dist/overlay.js"
      },
      "require": {
        "types": "./dist/overlay.d.cts",
        "default": "./dist/overlay.cjs"
      }
    },
    "./qwik": {
      "import": {
        "types": "./dist/qwik.d.ts",
        "default": "./dist/qwik.js"
      },
      "require": {
        "types": "./dist/qwik.d.cts",
        "default": "./dist/qwik.cjs"
      }
    },
    "./solid": {
      "solid": "./dist/solid.source.jsx",
      "import": {
        "types": "./dist/solid.d.ts",
        "default": "./dist/solid.js"
      },
      "require": {
        "types": "./dist/solid.d.cts",
        "default": "./dist/solid.cjs"
      }
    },
    "./integrations/react-hook-form": {
      "import": {
        "types": "./dist/integrations/react-hook-form.d.ts",
        "default": "./dist/integrations/react-hook-form.js"
      },
      "require": {
        "types": "./dist/integrations/react-hook-form.d.cts",
        "default": "./dist/integrations/react-hook-form.cjs"
      }
    },
    "./integrations/formik": {
      "import": {
        "types": "./dist/integrations/formik.d.ts",
        "default": "./dist/integrations/formik.js"
      },
      "require": {
        "types": "./dist/integrations/formik.d.cts",
        "default": "./dist/integrations/formik.cjs"
      }
    },
    "./package.json": "./package.json",
    "./styles": "./dist/styles.css",
    "./styles.css": "./dist/styles.css",
    "./themes/ios": "./dist/themes/ios.css",
    "./themes/ios.css": "./dist/themes/ios.css",
    "./themes/material": "./dist/themes/material.css",
    "./themes/material.css": "./dist/themes/material.css",
    "./themes/vercel": "./dist/themes/vercel.css",
    "./themes/vercel.css": "./dist/themes/vercel.css"
  },
  "workspaces": [
    "examples/*"
  ],
  "size-limit": [
    {
      "name": "core (engine + types)",
      "path": "dist/index.js",
      "limit": "22 KB",
      "gzip": true
    },
    {
      "name": "react adapter",
      "path": "dist/react.js",
      "limit": "25 KB",
      "gzip": true
    },
    {
      "name": "vue adapter",
      "path": "dist/vue.js",
      "limit": "20 KB",
      "gzip": true
    },
    {
      "name": "svelte adapter",
      "path": "dist/svelte.js",
      "limit": "21 KB",
      "gzip": true
    },
    {
      "name": "solid adapter",
      "path": "dist/solid.js",
      "limit": "20 KB",
      "gzip": true
    },
    {
      "name": "qwik adapter",
      "path": "dist/qwik.js",
      "limit": "18 KB",
      "gzip": true
    },
    {
      "name": "preact adapter (re-export only)",
      "path": "dist/preact.js",
      "limit": "1 KB",
      "gzip": true,
      "ignore": [
        "./react.js"
      ]
    },
    {
      "name": "web component (self-contained)",
      "path": "dist/element.js",
      "limit": "24 KB",
      "gzip": true
    },
    {
      "name": "web component (IIFE / CDN)",
      "path": "dist/element.iife.global.js",
      "limit": "24 KB",
      "gzip": true
    },
    {
      "name": "overlay (subpath)",
      "path": "dist/overlay.js",
      "limit": "6.5 KB",
      "gzip": true
    }
  ],
  "files": [
    "dist",
    "!dist/**/*.map",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "prebuild": "node ./scripts/clean-dist.mjs && node ./scripts/inline-base-css.mjs",
    "build": "tsup && tsup --config tsup.solid.config.ts && tsup --config tsup.iife.config.ts",
    "postbuild": "node ./scripts/copy-d-ts-templates.mjs && node ./scripts/fix-preact-dist.mjs && node ./scripts/strip-icloud-dupes.mjs",
    "sync:css": "node ./scripts/inline-base-css.mjs",
    "dev": "tsup --watch",
    "demo": "vite",
    "demo:build": "vite build",
    "demo:preview": "vite build && vite preview",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "bench": "vitest bench",
    "size": "size-limit",
    "docs:api": "typedoc",
    "lhci": "lhci autorun --config=./lighthouserc.json",
    "prepublishOnly": "npm run build",
    "prepare": "husky && node ./scripts/postinstall-patches.mjs"
  },
  "peerDependencies": {
    "@builder.io/qwik": ">=1.0.0",
    "formik": ">=2.0.0",
    "preact": ">=10.0.0",
    "preact-render-to-string": ">=6.0.0",
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0",
    "react-hook-form": ">=7.0.0",
    "solid-js": ">=1.0.0",
    "svelte": ">=5.0.0",
    "vue": ">=3.2.0"
  },
  "peerDependenciesMeta": {
    "@builder.io/qwik": {
      "optional": true
    },
    "formik": {
      "optional": true
    },
    "preact": {
      "optional": true
    },
    "preact-render-to-string": {
      "optional": true
    },
    "react": {
      "optional": true
    },
    "react-dom": {
      "optional": true
    },
    "react-hook-form": {
      "optional": true
    },
    "vue": {
      "optional": true
    },
    "svelte": {
      "optional": true
    },
    "solid-js": {
      "optional": true
    }
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "^0.18.3",
    "@axe-core/playwright": "^4.11.2",
    "@builder.io/qwik": "^1.19.2",
    "@lhci/cli": "^0.15.1",
    "@playwright/test": "^1.59.1",
    "@size-limit/preset-small-lib": "^12.1.0",
    "@sveltejs/vite-plugin-svelte": "^4.0.4",
    "@types/node": "^20.11.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@vitejs/plugin-react": "^4.2.0",
    "@vitejs/plugin-vue": "^5.0.0",
    "@vitest/coverage-v8": "^1.2.0",
    "esbuild-plugin-solid": "^0.6.0",
    "esbuild-svelte": "^0.9.4",
    "fast-check": "^4.7.0",
    "happy-dom": "^13.3.0",
    "husky": "^9.1.7",
    "lit": "^3.3.2",
    "patch-package": "^8.0.1",
    "publint": "^0.3.21",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "rolldown": "^1.0.0-rc.18",
    "size-limit": "^12.1.0",
    "solid-js": "^1.9.12",
    "svelte": "^5.55.5",
    "tsup": "^8.0.1",
    "typescript": "^5.3.3",
    "unplugin-vue": "^7.2.0",
    "vite": "^5.0.10",
    "vite-plugin-solid": "^2.11.12",
    "vitest": "^1.6.1",
    "vue": "^3.4.0",
    "vue-tsc": "^1.8.27"
  },
  "engines": {
    "node": ">=20"
  }
}
